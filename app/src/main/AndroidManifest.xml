<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.spacecolony">

    <application
        android:name=".ColonyApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpaceColony">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".ui.RecruitActivity"
            android:exported="false"
            android:label="@string/title_recruit"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.QuartersActivity"
            android:exported="false"
            android:label="@string/title_quarters"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.SimulatorActivity"
            android:exported="false"
            android:label="@string/title_simulator"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.MissionControlActivity"
            android:exported="false"
            android:label="@string/title_mission_control"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.MissionActivity"
            android:exported="false"
            android:label="Mission"
            android:parentActivityName=".ui.MissionControlActivity"/>

        <activity android:name=".ui.StatisticsActivity"
            android:exported="false"
            android:label="@string/title_statistics"
            android:parentActivityName=".ui.MainActivity"/>

        <activity android:name=".ui.MedbayActivity"
            android:exported="false"
            android:label="@string/title_medbay"
            android:parentActivityName=".ui.MainActivity"/>

    </application>
</manifest>
