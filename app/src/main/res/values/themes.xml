<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Use NoActionBar because the activities are using a Toolbar in their layouts
        and calling setSupportActionBar().
    -->
    <style name="Theme.SpaceColony" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:textColorPrimary">@color/colorText</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>

        <!-- Force dark dialogs -->
        <item name="alertDialogTheme">@style/Theme.SpaceColony.Dialog</item>
        <item name="android:alertDialogTheme">@style/Theme.SpaceColony.Dialog</item>
    </style>

    <!-- Custom Dialog Style to fix visibility issues -->
    <style name="Theme.SpaceColony.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <!-- Dialog Background -->
        <item name="android:windowBackground">@color/colorCard</item>
        <item name="colorSurface">@color/colorCard</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="android:textColor">@color/white</item>

        <!-- Button Colors -->
        <item name="colorAccent">@color/colorAccent</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.MaterialComponents.Button.TextButton.Dialog</item>
    </style>

    <style name="Widget.MaterialComponents.Button.TextButton.Dialog" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

    <style name="ActionButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="backgroundTint">@color/colorAccent</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="strokeColor">@color/colorAccent</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>
