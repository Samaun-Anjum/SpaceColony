<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimaryDark"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        android:titleTextColor="@color/colorAccent"/>

    <TextView android:id="@+id/tv_mission_counter"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Missions launched: 0"
        android:textColor="@color/colorAccent"
        android:textSize="13sp"
        android:padding="12dp"/>

    <TextView android:id="@+id/tv_selection_info"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Select 2 or 3 crew members for a mission"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tv_empty_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No crew in Mission Control.\nMove crew here from Quarters."
        android:textColor="@color/colorTextSecondary"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_crew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorPrimaryDark"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        android:padding="12dp">

        <Button android:id="@+id/btn_to_quarters"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="🏠 Return Selected to Quarters"
            android:backgroundTint="@color/colorSurface"
            android:textColor="@color/colorText"/>

        <Button android:id="@+id/btn_launch_mission"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🚀 LAUNCH MISSION"
            android:backgroundTint="@color/colorDanger"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="17sp"/>
    </LinearLayout>
</LinearLayout>
